<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rude Potatoes | The Ultimate List</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <style>
        :root {
            --rude-yellow: #ffcc00;
            --rude-dark: #121212;
            --rude-card: #1e1e1e;
            --text-light: #ffffff;
        }

        body { 
            font-family: 'Impact', 'Arial Black', sans-serif; 
            background: var(--rude-dark); 
            color: var(--text-light);
            margin: 0; padding: 0;
        }

        header { background: #000; padding: 30px; text-align: center; border-bottom: 5px solid var(--rude-yellow); }
        h1 { font-size: 3.5rem; margin: 0; color: var(--rude-yellow); letter-spacing: 2px; }

        #map { height: 450px; width: 100%; border-bottom: 3px solid var(--rude-yellow); z-index: 1; }

        .search-container { padding: 30px; text-align: center; background: #1a1a1a; }
        #searchBox { 
            padding: 15px 25px; width: 80%; max-width: 600px; 
            border-radius: 30px; border: 2px solid var(--rude-yellow); 
            background: #000; color: white; font-size: 1.1rem; outline: none;
        }

        .grid { 
            display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
            gap: 30px; padding: 40px; max-width: 1400px; margin: 0 auto; 
        }

        .card { 
            background: var(--rude-card); border: 1px solid #333;
            padding: 25px; position: relative; transition: 0.3s ease;
        }
        .card:hover { transform: translateY(-10px); border-color: var(--rude-yellow); }
        
        .score-badge { 
            position: absolute; top: -15px; right: -10px; 
            background: var(--rude-yellow); color: #000; 
            padding: 8px 15px; font-size: 1.8rem; font-weight: bold;
            transform: rotate(5deg); box-shadow: 4px 4px 0px #fff;
        }

        .name { font-size: 1.6rem; color: var(--rude-yellow); text-transform: uppercase; margin-bottom: 5px; display: block; }
        .address { color: #aaa; font-family: sans-serif; font-size: 0.9rem; margin-bottom: 15px; display: block; }
        
        .btn-insta { 
            display: inline-block; background: transparent; 
            color: var(--rude-yellow); border: 2px solid var(--rude-yellow);
            padding: 10px 20px; text-decoration: none; font-family: sans-serif;
            font-weight: bold; text-transform: uppercase; font-size: 0.8rem; transition: 0.3s;
        }
        .btn-insta:hover { background: var(--rude-yellow); color: #000; }

        /* Estilo de los Popups del Mapa */
        .leaflet-popup-content-wrapper { background: #000; color: #fff; border: 1px solid var(--rude-yellow); border-radius: 0; }
        .leaflet-popup-tip { background: var(--rude-yellow); }
    </style>
</head>
<body>

    <header>
        <h1>RUDE POTATOES</h1>
        <p style="margin:5px; font-family:sans-serif; letter-spacing:5px;">THE ULTIMATE LIST</p>
    </header>

    <div id="map"></div>

    <div class="search-container">
        <input type="text" id="searchBox" placeholder="BUSCA TU BARRIO O LOCAL..." onkeyup="filterData()">
    </div>

    <div id="potato-grid" class="grid">
        <p style="text-align:center; width:100%;">Cargando arsenal de patatas...</p>
    </div>

    <script>
        // URL RAW DE TU GITHUB
        const csvUrl = 'https://raw.githubusercontent.com/Rudepotatoes/Rudepotatoes/main/Rude%20Potatoes_%20The%20Ultimate%20List%20-%20Hoja%201.csv';
        
        let allData = [];
        let map;
        let markers = [];

        // Icono de Patatas Fritas
        const potatoIcon = L.icon({
            iconUrl: 'https://cdn-icons-png.flaticon.com/512/1046/1046786.png',
            iconSize: [35, 35],
            iconAnchor: [17, 34],
            popupAnchor: [0, -30]
        });

        // 1. Inicializar Mapa (Centrado en Barcelona)
        map = L.map('map').setView([41.387, 2.170], 13);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: 'Rude Potatoes'
        }).addTo(map);

        // 2. Cargar Datos
        Papa.parse(csvUrl, {
            download: true,
            header: true,
            skipEmptyLines: true,
            complete: function(results) {
                console.log("Columnas leídas:", Object.keys(results.data[0])); // Debug para ver nombres reales

                allData = results.data.map(row => {
                    // Mapeo flexible por si cambian los nombres en el CSV
                    const name = row['Bar'] || row['Name'] || "Local";
                    const ciudad = row['Ciudad'] || "Barcelona";
                    const barrio = row['Barrio'] || "";
                    const instagram = row['Instagram'] || "#";
                    
                    // Calculamos nota media (P/Sabor + P/Textura)
                    const s = parseFloat(String(row['P/Sabor']).replace(',', '.')) || 0;
                    const t = parseFloat(String(row['P/Textura']).replace(',', '.')) || 0;
                    const score = (s > 0) ? ((s + t) / 2).toFixed(1) : "N/A";

                    // Coordenadas (Limpieza de comas)
                    const lat = parseFloat(String(row['Latitude']).replace(',', '.').trim());
                    const lng = parseFloat(String(row['Longitude']).replace(',', '.').trim());

                    return { name, address: `${barrio} ${ciudad}`, score, lat, lng, instagram };
                }).filter(item => item.name !== "Local");

                // Ordenar por nota de mayor a menor
                allData.sort((a, b) => (b.score === "N/A" ? 0 : b.score) - (a.score === "N/A" ? 0 : a.score));

                render(allData);
            }
        });

        function render(data) {
            const container = document.getElementById('potato-grid');
            container.innerHTML = '';
            
            // Limpiar Mapa
            markers.forEach(m => map.removeLayer(m));
            markers = [];

            data.forEach(item => {
                // Crear Tarjeta
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <div class="score-badge">${item.score}</div>
                    <span class="name">${item.name}</span>
                    <span class="address">📍 ${item.address}</span>
                    <a href="${item.instagram}" target="_blank" class="btn-insta">Ver en Instagram</a>
                `;
                container.appendChild(card);

                // Crear Marcador si hay coordenadas
                if (!isNaN(item.lat) && !isNaN(item.lng)) {
                    const m = L.marker([item.lat, item.lng], { icon: potatoIcon })
                        .addTo(map)
                        .bindPopup(`<b>${item.name}</b><br>Nota: ${item.score}`);
                    markers.push(m);
                }
            });

            // Ajustar mapa si hay marcadores
            if (markers.length > 0) {
                const group = new L.featureGroup(markers);
                map.fitBounds(group.getBounds().pad(0.1));
            }
        }

        function filterData() {
            const val = document.getElementById('searchBox').value.toLowerCase();
            const filtered = allData.filter(i => 
                i.name.toLowerCase().includes(val) || 
                i.address.toLowerCase().includes(val)
            );
            render(filtered);
        }
    </script>
</body>
</html>
